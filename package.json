{
	"name": "bespoke-digital-website",
	"version": "1.0.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^5.2.7",
		"@mailchimp/mailchimp_transactional": "^1.3.3",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.58.2",
		"@portabletext/svelte": "^2.1.12",
		"@sanity/client": "^6.29.1",
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@types/cookie": "^0.6.0",
		"@types/mailchimp__mailchimp_transactional": "^1.0.11",
		"@types/nodemailer": "^6.4.23",
		"@types/sanitize-html": "^2.16.0",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-svelte": "^2.46.1",
		"fastest-validator": "^1.19.1",
		"google-auth-library": "^9.15.1",
		"google-spreadsheet": "^4.1.5",
		"gsap": "^3.14.2",
		"luxon": "^3.7.2",
		"nodemailer": "^6.10.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sanitize-html": "^2.17.1",
		"svelte": "^4.2.20",
		"svelte-check": "^3.8.6",
		"svelte-intersection-observer": "^1.1.1",
		"swiper": "^11.2.10",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"video.js": "^8.23.7",
		"vite": "^5.4.21",
		"vitest": "^1.6.1"
	},
	"type": "module"
}
